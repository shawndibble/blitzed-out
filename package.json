{
  "homepage": "https://blitzedout.com",
  "type": "module",
  "name": "blitzed-out",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predeploy": "npm run build",
    "deploy": "gh-pages -b master -d dist",
    "lint": "eslint --format=compact --ext .js,.jsx,.ts,.tsx .",
    "format": "prettier --write .",
    "start": "vite",
    "build": "tsc --project tsconfig.build.json && vite build",
    "prepare": "husky",
    "test": "NODE_OPTIONS='--max-old-space-size=4096' vitest",
    "test:failures": "NODE_OPTIONS='--max-old-space-size=2048' vitest run --no-watch --reporter=dot --bail=10 --silent=passed-only --config=vitest.ci.config.ts",
    "test:ci": "NODE_OPTIONS='--max-old-space-size=2048' vitest run --no-watch --reporter=dot --bail=3 --config=vitest.ci.config.ts",
    "test:timing": "NODE_OPTIONS='--max-old-space-size=2048' vitest run --no-watch --reporter=verbose --config=vitest.ci.config.ts",
    "type-check": "tsc --noEmit",
    "cleanup:debug": "eslint --rule 'no-console: error' src/",
    "cleanup:comments": "eslint --rule 'no-warning-comments: [error, { terms: [todo, fixme, hack, bug], location: anywhere }]' src/",
    "validate:placeholders": "node scripts/validate-placeholders.cjs"
  },
  "dependencies": {
    "@3d-dice/dice-box-threejs": "^0.0.12",
    "@capacitor/camera": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@fontsource/roboto": "^5.2.5",
    "@ionic/pwa-elements": "^3.2.2",
    "@mui/icons-material": "^7.0.0",
    "@mui/material": "^7.0.1",
    "@mui/x-date-pickers": "^8.0.0",
    "@sentry/react": "^10.50.0",
    "@sentry/tracing": "^7.120.4",
    "@sentry/vite-plugin": "^5.2.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/simple-peer": "^9.11.9",
    "clsx": "^2.1.0",
    "dayjs": "^1.11.10",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.27.0",
    "firebase": "^12.12.1",
    "framer-motion": "^12.23.12",
    "gh-pages": "^6.0.0",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.0.4",
    "i18next-resources-to-backend": "^1.2.1",
    "ios-haptics": "^0.1.4",
    "js-sha256": "^0.11.0",
    "nanoid": "^5.1.9",
    "qrcode.react": "^4.2.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-i18next": "^16.0.0",
    "react-markdown": "^10.0.0",
    "react-router-dom": "^7.14.2",
    "react-string-replace": "^2.0.0",
    "remark-gemoji": "^8.0.0",
    "remark-gfm": "^4.0.1",
    "simple-peer": "^9.11.1",
    "use-sound": "^5.0.0",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@capacitor/cli": "8.3.1",
    "@eslint-react/eslint-plugin": "2.13.0",
    "@eslint/js": "10.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@vitejs/plugin-react-swc": "4.3.0",
    "@vitest/ui": "4.1.5",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-formatter-compact": "9.0.1",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react-refresh": "0.5.2",
    "fake-indexeddb": "6.2.5",
    "globals": "17.5.0",
    "husky": "9.1.7",
    "jsdom": "28.1.0",
    "lint-staged": "16.4.0",
    "msw": "2.13.6",
    "path": "0.12.7",
    "prettier": "3.8.3",
    "terser": "5.46.2",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vite-plugin-compression2": "2.5.3",
    "vitest": "4.1.5"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,css,scss,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
