{
  "homepage": "https://blitzedout.com",
  "type": "module",
  "name": "blitzed-out",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "predeploy": "npm run build",
    "deploy": "gh-pages -b master -d dist",
    "lint": "eslint --format=compact --ext .js,.jsx,.ts,.tsx .",
    "format": "prettier --write .",
    "start": "vite",
    "build": "tsc --project tsconfig.build.json && vite build",
    "prepare": "husky",
    "test": "NODE_OPTIONS='--max-old-space-size=4096' vitest",
    "test:failures": "NODE_OPTIONS='--max-old-space-size=2048' vitest run --no-watch --reporter=dot --bail=10 --silent=passed-only --config=vitest.ci.config.ts",
    "test:ci": "NODE_OPTIONS='--max-old-space-size=2048' vitest run --no-watch --reporter=dot --bail=3 --config=vitest.ci.config.ts",
    "test:timing": "NODE_OPTIONS='--max-old-space-size=2048' vitest run --no-watch --reporter=verbose --config=vitest.ci.config.ts",
    "test:rules": "PATH=\"$(brew --prefix openjdk 2>/dev/null)/bin:$PATH\" firebase emulators:exec --only firestore --project demo-blitzed 'vitest run --config=vitest.rules.config.ts'",
    "type-check": "tsc --noEmit",
    "cleanup:debug": "eslint --rule 'no-console: error' src/",
    "cleanup:comments": "eslint --rule 'no-warning-comments: [error, { terms: [todo, fixme, hack, bug], location: anywhere }]' src/",
    "validate:placeholders": "node scripts/validate-placeholders.cjs",
    "verify:pwa-build": "node scripts/verify-pwa-build.cjs"
  },
  "dependencies": {
    "@3d-dice/dice-box-threejs": "^0.0.12",
    "@capacitor/camera": "^8.2.1",
    "@capacitor/core": "^8.4.1",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@ionic/pwa-elements": "^3.4.0",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@mui/x-date-pickers": "^9.9.0",
    "@sentry/react": "^10.65.0",
    "@sentry/tracing": "^7.120.4",
    "@sentry/vite-plugin": "^5.4.0",
    "@tanstack/react-virtual": "^3.14.5",
    "@types/simple-peer": "^9.11.9",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.21",
    "dexie": "^4.4.4",
    "dexie-react-hooks": "^4.4.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "firebase": "^12.16.0",
    "framer-motion": "^12.42.2",
    "gh-pages": "^6.3.0",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-resources-to-backend": "^1.2.1",
    "js-sha256": "^0.11.1",
    "nanoid": "^5.1.16",
    "qrcode.react": "^4.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "^17.0.9",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "react-string-replace": "^2.0.1",
    "remark-gemoji": "^8.0.0",
    "remark-gfm": "^4.0.1",
    "simple-peer": "^9.11.1",
    "use-sound": "^5.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@capacitor/cli": "8.4.1",
    "@emnapi/core": "1.11.2",
    "@emnapi/runtime": "1.11.2",
    "@eslint-react/eslint-plugin": "5.14.5",
    "@eslint/js": "10.0.1",
    "@firebase/rules-unit-testing": "5.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "@vitejs/plugin-react-swc": "4.3.1",
    "@vitest/ui": "4.1.10",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-formatter-compact": "9.0.1",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react-refresh": "0.5.3",
    "fake-indexeddb": "6.2.5",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "lint-staged": "17.0.8",
    "msw": "2.15.0",
    "path": "0.12.7",
    "prettier": "3.9.5",
    "rollup-plugin-visualizer": "7.0.1",
    "terser": "5.49.0",
    "typescript": "6.0.3",
    "vite": "8.1.4",
    "vite-plugin-compression2": "2.5.3",
    "vite-plugin-pwa": "1.3.0",
    "vitest": "4.1.10"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,css,scss,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
