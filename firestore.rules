rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Optional URL: empty string, or an http(s) link, capped in length.
    function isValidOptionalUrl(url) {
      return url is string
        && url.size() <= 2048
        && (url == '' || url.matches('^https?://.+'));
    }

    function customActionCreateValid() {
      let data = request.resource.data;
      return data.keys().hasAll(['grouping', 'customAction', 'ttl'])
        && data.keys().hasOnly(['grouping', 'customAction', 'ttl'])
        && data.grouping is string && data.grouping.size() <= 100
        && data.customAction is string && data.customAction.size() <= 2000
        && data.ttl is timestamp;
    }

    function gameBoardCreateValid() {
      let data = request.resource.data;
      return data.keys().hasAll(['title', 'gameBoard', 'settings', 'checksum', 'ttl'])
        && data.keys().hasOnly(['title', 'gameBoard', 'settings', 'checksum', 'ttl'])
        && data.title is string && data.title.size() <= 200
        && data.gameBoard is string && data.gameBoard.size() <= 600000
        && data.settings is string && data.settings.size() <= 200000
        && data.checksum is string && data.checksum.size() <= 128
        && data.ttl is timestamp;
    }

    function scheduleCreateValid() {
      let data = request.resource.data;
      return data.keys().hasAll(['dateTime', 'url', 'room', 'createdBy'])
        && data.keys().hasOnly(['dateTime', 'url', 'room', 'createdBy'])
        && data.dateTime is timestamp
        && isValidOptionalUrl(data.url)
        && data.room is string && data.room.size() <= 64
        && data.createdBy == request.auth.uid;
    }

    function scheduleUpdateValid() {
      let data = request.resource.data;
      return resource.data.createdBy == request.auth.uid
        && data.createdBy == resource.data.createdBy
        && data.diff(resource.data).affectedKeys().hasOnly(['dateTime', 'url'])
        && data.dateTime is timestamp
        && isValidOptionalUrl(data.url);
    }

    function contentPackFieldsValid(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.description is string && data.description.size() <= 1000
        && data.gameMode in ['online', 'solo', 'local']
        && data.locale is string && data.locale.size() <= 10
        && data.tags is list && data.tags.size() <= 20
        && data.visibility in ['public', 'private']
        && data.tileCount is int && data.tileCount >= 0
        && data.groupCount is int && data.groupCount >= 0
        && data.groupLabels is list && data.groupLabels.size() <= 100
        && data.contents is string && data.contents.size() <= 600000
        && data.contentHash is string && data.contentHash.size() <= 128
        && data.authorName is string && data.authorName.size() <= 100
        && data.formatVersion is string && data.formatVersion.size() <= 16
        && data.updatedAt is number;
    }

    // Publishing to the public directory requires a permanent (non-anonymous)
    // account; anonymous users may still publish private (link-only) packs.
    function publicVisibilityGated(data) {
      return data.visibility == 'private'
        || request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function contentPackCreateValid() {
      let data = request.resource.data;
      return data.keys().hasOnly(['author', 'authorName', 'name', 'description', 'gameMode',
          'locale', 'tags', 'visibility', 'tileCount', 'groupCount', 'groupLabels', 'contents',
          'contentHash', 'packVersion', 'formatVersion', 'createdAt', 'updatedAt'])
        && data.keys().hasAll(['author', 'authorName', 'name', 'description', 'gameMode',
          'locale', 'tags', 'visibility', 'tileCount', 'groupCount', 'groupLabels', 'contents',
          'contentHash', 'packVersion', 'formatVersion', 'createdAt', 'updatedAt'])
        && data.author == request.auth.uid
        && data.packVersion is int && data.packVersion >= 1
        && data.createdAt is number
        && publicVisibilityGated(data)
        && contentPackFieldsValid(data);
    }

    function contentPackUpdateValid() {
      let data = request.resource.data;
      return resource.data.author == request.auth.uid       // only the author can republish
        && data.author == resource.data.author              // author immutable
        && data.createdAt == resource.data.createdAt         // createdAt immutable
        && data.packVersion is int
        && data.packVersion > resource.data.packVersion      // version must increase
        && data.diff(resource.data).affectedKeys().hasOnly(['name', 'description', 'tags',
          'visibility', 'tileCount', 'groupCount', 'groupLabels', 'contents', 'contentHash',
          'packVersion', 'updatedAt', 'authorName'])
        && publicVisibilityGated(data)
        && contentPackFieldsValid(data);
    }

    function reportCreateValid() {
      let data = request.resource.data;
      return data.keys().hasOnly(['packId', 'reporterUid', 'reason', 'createdAt'])
        && data.keys().hasAll(['packId', 'reporterUid', 'reason', 'createdAt'])
        && data.packId is string && data.packId.size() <= 128
        && data.reporterUid == request.auth.uid
        && data.reason is string && data.reason.size() <= 500
        && data.createdAt is number;
    }

    // User data - only authenticated users can access their own data
    match /user-data/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Custom actions - authenticated users can submit, anonymous read
    match /custom-actions/{actionId} {
      allow read: if true; // Public read for game content
      allow create: if isSignedIn() && customActionCreateValid();
      allow update, delete: if false; // No updates/deletes allowed
    }
    
    // Game boards - authenticated users can create, public read with TTL
    match /game-boards/{boardId} {
      allow read: if true; // Public read for sharing boards
      allow create: if isSignedIn() && gameBoardCreateValid();
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ttl']);
      allow delete: if false; // Let TTL handle cleanup
    }
    
    // Chat rooms and messages
    match /chat-rooms/{roomId} {
      // Allow read/write access to room metadata for authenticated users
      allow read, write: if request.auth != null;
      
      match /messages/{messageId} {
        // Allow reading all messages in a room for authenticated users (including anonymous)
        allow read: if request.auth != null;
        
        // Allow listing/querying messages in a room for authenticated users
        allow list: if request.auth != null;
        
        // Allow creating messages with validation
        allow create: if request.auth != null 
          && request.resource.data.keys().hasAll(['text', 'ttl', 'type', 'uid', 'displayName', 'timestamp'])
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() <= 1000 // Limit message length
          && request.resource.data.type in ['chat', 'actions', 'settings', 'room', 'media']
          && request.resource.data.ttl is timestamp;
          
        // Allow users to delete their own messages
        allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
        
        // No message editing allowed
        allow update: if false;
      }
    }
    
    // Rate limiting collection (internal use)
    match /rate-limits/{userId} {
      allow read, write: if false; // Only system can access
    }
    
    // Schedule - authenticated users can create, public read
    match /schedule/{scheduleId} {
      allow read: if true; // Public read for game schedules
      allow create: if isSignedIn() && scheduleCreateValid();
      allow update: if isSignedIn() && scheduleUpdateValid();
      allow delete: if isSignedIn()
        && resource.data.createdBy == request.auth.uid;
    }

    // Content packs - durable shareable tile/group bundles. Any pack is fetchable
    // by id (shared by code via ?importPack=<id>), but directory listing returns
    // public packs only — the `visibility == 'public'` filter is what enforces
    // this, since Firestore rejects any list query the rule can't satisfy. Only
    // the author can republish (version must increase) or take down; admins take
    // down via the `admin` custom claim.
    match /content-packs/{packId} {
      allow get: if true;
      allow list: if resource.data.visibility == 'public';
      allow create: if isSignedIn() && contentPackCreateValid();
      allow update: if isSignedIn() && contentPackUpdateValid();
      allow delete: if isSignedIn()
        && (resource.data.author == request.auth.uid || request.auth.token.admin == true);
    }

    // Abuse reports - any signed-in user can file; only admins read/act (console).
    match /reports/{reportId} {
      allow create: if isSignedIn() && reportCreateValid();
      allow read, update, delete: if false;
    }
  }
}
